# App
APP_NAME=Eco-Health Agentic Dietitian API
API_V1_STR=/api/v1
ENV=development
DEBUG=true

# LLM / Agent (Gemini via Railtracks)
GEMINI_API_KEY=
RAILTRACKS_ENABLED=false
RAILTRACKS_BASE_URL=
RAILTRACKS_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Vector Store (ChromaDB)
VECTOR_STORE_MODE=memory
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=eco_health
VECTOR_SNAPSHOT_PATH=./data/vector_snapshot.json

# AWS Cognito
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_ISSUER=
COGNITO_USER_POOL_ARN=
COGNITO_JWKS_URL=
COGNITO_JWKS_JSON=
COGNITO_JWKS_PATH=
AUTH_BYPASS_ENABLED=false

# Recipe API
RECIPE_API_BASE_URL=https://www.themealdb.com/api/json/v1/1
RECIPE_API_KEY=1

# Data
# Leave blank to use SQLITE_MODE defaults.
DATABASE_URL=
SQLITE_MODE=memory
SQLITE_SNAPSHOT_PATH=./data/eco_health.sqlite3
SQLITE_AUTO_SNAPSHOT=true
REDIS_URL=
